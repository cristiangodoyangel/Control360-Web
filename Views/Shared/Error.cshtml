@model Inventario360.Web.Models.ErrorViewModel
@{
    ViewBag.Title = "Error";
}

<h1 class="text-danger">Error</h1>
<h2 class="text-danger">Ocurrió un error al procesar tu solicitud.</h2>

@if (!string.IsNullOrEmpty(Model?.RequestId))
{
    <p>
        <strong>ID de la solicitud:</strong> <code>@Model.RequestId</code>
    </p>
}

<p>
    Si el problema persiste, contacta con el administrador del sistema.
</p>
